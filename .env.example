# Discord bot token
DISCORD_TOKEN=

# Channels to monitor for reactions (comma-separated IDs)
TARGET_CHANNEL_IDS=

# Channel to post the weekly summary (required)
SUMMARY_CHANNEL_ID=

# Negative reactions (comma-separated). Supports unicode or custom emojis.
# All other reactions count as positive.
# Examples:
# NEGATIVE_REACTIONS=👎,💀,partyblob:123456789012345678
NEGATIVE_REACTIONS=

# Ignored reactions (comma-separated). These are excluded entirely.
# Examples:
# IGNORED_REACTIONS=🤖,info:123456789012345678
IGNORED_REACTIONS=

# Leaderboard schedule (cron format). Default: 0 9 * * 1 (Mondays at 09:00)
LEADERBOARD_CRON=

# How many best posts to show in the full leaderboard thread
LEADERBOARD_LIMIT=10

# How many worst posts to show in the full leaderboard thread
WORST_POST_LIMIT=3

# Summary message title and optional description override
SUMMARY_TITLE=Weekly Reaction Summary
SUMMARY_DESCRIPTION=

# Thread title and auto-archive duration in minutes (60, 1440, 4320, 10080)
THREAD_TITLE=Weekly Leaderboard Details
THREAD_AUTO_ARCHIVE_MINUTES=10080

# Set to true only if Message Content Intent is enabled for the bot
MESSAGE_CONTENT_INTENT=false
