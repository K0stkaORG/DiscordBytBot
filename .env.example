# Discord bot token
DISCORD_TOKEN=

# Channel to monitor for reactions
TARGET_CHANNEL_ID=

# Channel to post the weekly leaderboard (defaults to target channel)
LEADERBOARD_CHANNEL_ID=

# Positive/negative reactions (comma-separated). Supports unicode or custom emojis.
# Examples:
# POSITIVE_REACTIONS=👍,🔥,partyblob:123456789012345678
# NEGATIVE_REACTIONS=👎,💀
POSITIVE_REACTIONS=
NEGATIVE_REACTIONS=

# Leaderboard schedule (cron format). Default: 0 9 * * 1 (Mondays at 09:00)
LEADERBOARD_CRON=

# How many posts to show
LEADERBOARD_LIMIT=10

# Set to true only if Message Content Intent is enabled for the bot
MESSAGE_CONTENT_INTENT=false
